# XRPL connection (PoC runs on testnet — see plan §0 rule 6)
XRPL_WSS=wss://s.altnet.rippletest.net:51233
XRPL_NETWORK=testnet

# Secrets / fulfillment custody. PoC uses a local mock; real deployment uses AWS KMS (report §2.3).
KMS_MODE=mock

# PostgreSQL (Fase C). Matches docker-compose.yml at the repo root.
# Set this (e.g. in a local .env) to run the Postgres integration tests.
DB_URL=postgres://avales:avales@localhost:5432/avales
